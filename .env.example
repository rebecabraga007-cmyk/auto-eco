# Mais Obras
MAISOBRAS_EMAIL=seu_email@exemplo.com
MAISOBRAS_PASSWORD=sua_senha
MAISOBRAS_BASE_URL=https://www.maisobras.online

# Mistral AI — usada para detectar colunas automaticamente em qualquer planilha
# Obtenha sua chave em https://console.mistral.ai/
MISTRAL_API_KEY=

# Opcional: se definido, exige header X-API-Token nas chamadas de API.
# Para a tela web simples, deixe vazio ou implemente login proprio antes de publicar.
API_TOKEN=

# Timeout das chamadas HTTP para o Mais Obras, em ms.
PLAYWRIGHT_TIMEOUT=30000

# Limite maximo de obras por planilha.
MAX_OBRAS_PER_REQUEST=1500
